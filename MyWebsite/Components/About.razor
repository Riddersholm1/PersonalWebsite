<section id="about" class="page-section">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudStack Spacing="6">
            <MudStack Spacing="2" AlignItems="AlignItems.Center" Class="section-heading">
                <MudText Typo="Typo.overline" Color="Color.Primary">Hvem er jeg</MudText>
                <MudText Typo="Typo.h3" Align="Align.Center">Om mig</MudText>
                <MudDivider Class="section-divider" />
            </MudStack>

            <MudGrid Spacing="6" Justify="Justify.Center">
                <MudItem xs="12" md="7">
                    <MudStack Spacing="4">
                        <MudText Typo="Typo.body1" Class="about-paragraph">
                            Jeg bor i Rødekro og arbejder som softwareudvikler hos AL Sydbank, hvor jeg bygger
                            og vedligeholder løsninger, der understøtter vigtige forretningsprocesser.
                            Jeg trives bedst, når jeg kan omsætte komplekse behov til enkle, robuste og brugervenlige
                            webapplikationer med Blazor og C#.
                        </MudText>
                        <MudText Typo="Typo.body1" Class="about-paragraph">
                            Jeg interesserer mig især for software, der både er teknisk stærkt og skaber reel værdi.
                            Derfor lægger jeg vægt på tydelig arkitektur, høj kodekvalitet og løsninger, der kan
                            videreudvikles over tid. Jeg har en pragmatisk tilgang til udvikling og forsøger altid
                            at finde balancen mellem design, performance og forretningsmål.
                        </MudText>
                        <MudText Typo="Typo.body1" Class="about-paragraph">
                            Uden for arbejdet er jeg langsigtet investor og motiveres af at forstå virksomheder,
                            data og beslutninger i dybden. Den analytiske tilgang tager jeg også med ind i
                            udviklingsarbejdet, hvor jeg sætter pris på struktur, overblik og gennemtænkte valg.
                        </MudText>
                    </MudStack>
                </MudItem>

                <MudItem xs="12" md="5">
                    <MudPaper Elevation="2" Class="about-card">
                        <MudStack Spacing="4">
                            <MudText Typo="Typo.h6">Overblik</MudText>
                            <MudDivider />
                            <MudStack Row Spacing="3" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Primary" />
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.subtitle2">Lokation</MudText>
                                    <MudText Typo="Typo.body2">Rødekro, Danmark</MudText>
                                </MudStack>
                            </MudStack>
                            <MudStack Row Spacing="3" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Work" Color="Color.Primary" />
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.subtitle2">Rolle</MudText>
                                    <MudText Typo="Typo.body2">Softwareudvikler hos AL Sydbank</MudText>
                                </MudStack>
                            </MudStack>
                            <MudStack Row Spacing="3" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Code" Color="Color.Primary" />
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.subtitle2">Fokus</MudText>
                                    <MudText Typo="Typo.body2">.NET, Blazor og MSSQL</MudText>
                                </MudStack>
                            </MudStack>
                            <MudStack Row Spacing="3" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Primary" />
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.subtitle2">Interesse</MudText>
                                    <MudText Typo="Typo.body2">Langsigtede investeringer</MudText>
                                </MudStack>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudStack>
    </MudContainer>
</section>
