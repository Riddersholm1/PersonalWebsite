<section id="projects" class="page-section">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudStack Spacing="6">
            <MudStack Spacing="2" AlignItems="AlignItems.Center" Class="section-heading">
                <MudText Typo="Typo.overline" Color="Color.Primary">Udvalgte arbejder</MudText>
                <MudText Typo="Typo.h3" Align="Align.Center">Projekter</MudText>
                <MudDivider Class="section-divider" />
            </MudStack>

            <MudGrid Spacing="4">
                <MudItem xs="12" sm="6">
                    <MudCard Elevation="2" Class="project-card">
                        <MudCardContent>
                            <MudStack Spacing="3">
                                <MudIcon Icon="@Icons.Material.Filled.Web" Color="Color.Primary" Size="Size.Large" />
                                <MudText Typo="Typo.h6">Personlig hjemmeside</MudText>
                                <MudText Typo="Typo.body2" Class="project-description">
                                    Denne hjemmeside &ndash; bygget med Blazor WebAssembly og MudBlazor.
                                    Hostet på Cloudflare Pages via GitHub.
                                </MudText>
                                <MudStack Row Class="chip-row" Spacing="1">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">Blazor</MudChip>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">.NET</MudChip>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">MudBlazor</MudChip>
                                </MudStack>
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Href="https://github.com/Riddersholm1/PersonalWebsite"
                                       Target="_blank"
                                       Variant="Variant.Text"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Custom.Brands.GitHub">
                                GitHub
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudCard Elevation="2" Class="project-card">
                        <MudCardContent>
                            <MudStack Spacing="3">
                                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Primary" Size="Size.Large" />
                                <MudText Typo="Typo.h6">Stock Insight Værktøj</MudText>
                                <MudText Typo="Typo.body2" Class="project-description">
                                    En Blazor-applikation der henter og visualiserer aktie-fundamentaler
                                    ved hjælp af gratis API'er.
                                </MudText>
                                <MudStack Row Class="chip-row" Spacing="1">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">Blazor</MudChip>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">C#</MudChip>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">API</MudChip>
                                </MudStack>
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Href="https://github.com/Riddersholm1"
                                       Target="_blank"
                                       Variant="Variant.Text"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Custom.Brands.GitHub">
                                GitHub
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudStack>
    </MudContainer>
</section>
