<section id="education" class="page-section">
    <MudContainer MaxWidth="MaxWidth.Medium">
        <MudStack Spacing="4">
            <MudText Typo="Typo.h3">Uddannelse</MudText>

            <MudTimeline TimelinePosition="TimelinePosition.Left">

                <MudTimelineItem Color="Color.Secondary" Icon="@Icons.Material.Filled.School"
                                 Size="Size.Medium" Variant="Variant.Filled">
                    <ItemOpposite>
                        <MudText Typo="Typo.caption">sep. 2021 – feb. 2022</MudText>
                    </ItemOpposite>
                    <ItemContent>
                        <MudPaper Elevation="2" Class="pa-4 experience-card">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.h6">Forretningsspecialisering</MudText>
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Aarhus Universitet</MudText>
                                <MudText Typo="Typo.caption">Forretning</MudText>
                            </MudStack>
                        </MudPaper>
                    </ItemContent>
                </MudTimelineItem>

                <MudTimelineItem Color="Color.Primary" Icon="@Icons.Material.Filled.School"
                                 Size="Size.Medium" Variant="Variant.Filled">
                    <ItemOpposite>
                        <MudText Typo="Typo.caption">feb. 2018 – jul. 2021</MudText>
                    </ItemOpposite>
                    <ItemContent>
                        <MudPaper Elevation="2" Class="pa-4 experience-card">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.h6">Diplomingeniør</MudText>
                                <MudText Typo="Typo.subtitle2" Color="Color.Primary">Aarhus Universitet</MudText>
                                <MudText Typo="Typo.caption">Elektronik</MudText>
                            </MudStack>
                        </MudPaper>
                    </ItemContent>
                </MudTimelineItem>

                <MudTimelineItem Color="Color.Default" Icon="@Icons.Material.Filled.MenuBook"
                                 Size="Size.Small" Variant="Variant.Outlined">
                    <ItemOpposite>
                        <MudText Typo="Typo.caption">aug. 2013 – jun. 2016</MudText>
                    </ItemOpposite>
                    <ItemContent>
                        <MudPaper Elevation="1" Class="pa-3 experience-card">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.subtitle1">STX</MudText>
                                <MudText Typo="Typo.subtitle2">Tønder Gymnasium</MudText>
                                <MudText Typo="Typo.caption">Naturvidenskabelig linje</MudText>
                            </MudStack>
                        </MudPaper>
                    </ItemContent>
                </MudTimelineItem>

            </MudTimeline>
        </MudStack>
    </MudContainer>
</section>


