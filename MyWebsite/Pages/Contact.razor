@page "/contact"

<section id="contact">
    <MudContainer MaxWidth="MaxWidth.Medium">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h3">Contact</MudText>
            <MudText Typo="Typo.body1">Get in touch through one of the links below.</MudText>
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                <MudButton Href="mailto:jesper@example.com" Variant="Variant.Filled">Email</MudButton>
                <MudButton Href="https://www.linkedin.com/in/jesper-riddersholm/" Target="_blank" Variant="Variant.Outlined">LinkedIn</MudButton>
            </MudStack>
        </MudStack>
    </MudContainer>
</section>
