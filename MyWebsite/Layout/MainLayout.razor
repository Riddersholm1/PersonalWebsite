@using MyWebsite.Theme

@inherits LayoutComponentBase

<MudThemeProvider IsDarkMode="_isDarkMode" Theme="MudBlazorTheme.Get()" />
<MudPopoverProvider />
<MudDialogProvider CloseButton="true" MaxWidth="@MaxWidth.Medium" FullWidth="false" BackdropClick="false" CloseOnEscapeKey="true" Position="@DialogPosition.Center" />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudText Typo="Typo.h5" Class="app-bar-title">Jesper Riddersholm</MudText>

        <MudSpacer />

        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@ToggleTheme" />
    </MudAppBar>

    <MudMainContent>
        @Body
    </MudMainContent>

    <Footer></Footer>
</MudLayout>
