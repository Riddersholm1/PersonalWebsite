@using MyWebsite.Theme

@inherits LayoutComponentBase

<MudThemeProvider IsDarkMode="_isDarkMode" Theme="MudBlazorTheme.Get()" />
<MudPopoverProvider />
<MudDialogProvider CloseButton="true" MaxWidth="@MaxWidth.Medium" FullWidth="false" BackdropClick="false" CloseOnEscapeKey="true" Position="@DialogPosition.Center" />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudText Typo="Typo.h5" Class="app-bar-title">Jesper Bruhn Riddersholm</MudText>

        <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="d-none d-lg-flex ml-4">
            <MudButton Href="#home" Variant="@(IsActiveSection("home") ? Variant.Filled : Variant.Text)">Hjem</MudButton>
            <MudButton Href="#about" Variant="@(IsActiveSection("about") ? Variant.Filled : Variant.Text)">Om mig</MudButton>
            <MudButton Href="#skills" Variant="@(IsActiveSection("skills") ? Variant.Filled : Variant.Text)">Kompetencer</MudButton>
            <MudButton Href="#projects" Variant="@(IsActiveSection("projects") ? Variant.Filled : Variant.Text)">Projekter</MudButton>
            <MudButton Href="#experience" Variant="@(IsActiveSection("experience") ? Variant.Filled : Variant.Text)">Erfaring</MudButton>
            <MudButton Href="#education" Variant="@(IsActiveSection("education") ? Variant.Filled : Variant.Text)">Uddannelse</MudButton>
            <MudButton Href="#contact" Variant="@(IsActiveSection("contact") ? Variant.Filled : Variant.Text)">Kontakt</MudButton>
        </MudStack>

        <MudSpacer />

        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@ToggleTheme" />
    </MudAppBar>

    <MudMainContent>
        @Body
    </MudMainContent>

    <Footer></Footer>
</MudLayout>
