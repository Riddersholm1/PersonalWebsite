@using MyWebsite.Theme

@inherits LayoutComponentBase

<MudThemeProvider IsDarkMode="_isDarkMode" Theme="MudBlazorTheme.Get()" />
<MudPopoverProvider />
<MudDialogProvider CloseButton="true" MaxWidth="@MaxWidth.Medium" FullWidth="false" BackdropClick="false" CloseOnEscapeKey="true" Position="@DialogPosition.Center" />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudStack Row AlignItems="AlignItems.Center" Spacing="4">
            <MudText Typo="Typo.h5">Jespers Portfolio</MudText>

            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                <MudButton Href="#home" Variant="@(IsActiveSection("home") ? Variant.Filled : Variant.Text)">Home</MudButton>
                <MudButton Href="#about" Variant="@(IsActiveSection("about") ? Variant.Filled : Variant.Text)">About</MudButton>
                <MudButton Href="#skills" Variant="@(IsActiveSection("skills") ? Variant.Filled : Variant.Text)">Skills</MudButton>
                <MudButton Href="#experience" Variant="@(IsActiveSection("experience") ? Variant.Filled : Variant.Text)">Experience</MudButton>
                <MudButton Href="#projects" Variant="@(IsActiveSection("projects") ? Variant.Filled : Variant.Text)">Projects</MudButton>
                <MudButton Href="#education" Variant="@(IsActiveSection("education") ? Variant.Filled : Variant.Text)">Education</MudButton>
                <MudButton Href="#contact" Variant="@(IsActiveSection("contact") ? Variant.Filled : Variant.Text)">Contact</MudButton>
            </MudStack>
        </MudStack>

        <MudSpacer />

        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       Edge="Edge.End"
                       OnClick="ToggleTheme" />
    </MudAppBar>
    <MudMainContent>
        @Body
    </MudMainContent>

    <Footer></Footer>
</MudLayout>