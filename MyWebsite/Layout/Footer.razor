<footer>
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudStack Spacing="3" AlignItems="AlignItems.Center">
            <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="2">
                <MudIconButton Href="https://github.com/Riddersholm1"
                               Target="_blank"
                               Icon="@Icons.Custom.Brands.GitHub"
                               Color="Color.Inherit"
                               Size="Size.Medium" />
                <MudIconButton Href="https://x.com/Riddersholm1"
                               Target="_blank"
                               Icon="@XBrandIcon"
                               Color="Color.Inherit"
                               Size="Size.Medium" />
                <MudIconButton Href="https://www.linkedin.com/in/jesper-riddersholm/"
                               Target="_blank"
                               Icon="@Icons.Custom.Brands.LinkedIn"
                               Color="Color.Inherit"
                               Size="Size.Medium" />
            </MudStack>

            <MudText Typo="Typo.body2" Align="Align.Center">
                &copy; @DateTime.Now.Year Jesper Bruhn Riddersholm
            </MudText>

            <MudText Typo="Typo.caption" Align="Align.Center">
                Bygget med
                <MudLink Href="https://dotnet.microsoft.com/" Target="_blank" Color="Color.Primary">.NET 10</MudLink> og
                <MudLink Href="https://mudblazor.com/" Target="_blank" Color="Color.Primary">MudBlazor</MudLink>
            </MudText>
        </MudStack>
    </MudContainer>
</footer>

@code {
    private const string XBrandIcon = "<path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\"/>";
}
