<footer>
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudStack Spacing="3" AlignItems="AlignItems.Center">
            <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="2">
                <MudIconButton Href="https://github.com/Riddersholm1"
                               Target="_blank"
                               Icon="@Icons.Custom.Brands.GitHub"
                               Color="Color.Inherit"
                               Size="Size.Medium" />
                <MudIconButton Href="https://www.linkedin.com/in/jesper-riddersholm/"
                               Target="_blank"
                               Icon="@Icons.Custom.Brands.LinkedIn"
                               Color="Color.Inherit"
                               Size="Size.Medium" />
            </MudStack>

            <MudText Typo="Typo.body2" Align="Align.Center">
                &copy; @DateTime.Now.Year Jesper Riddersholm
            </MudText>

            <MudText Typo="Typo.caption" Align="Align.Center">
                Bygget med
                <MudLink Href="https://dotnet.microsoft.com/" Target="_blank" Color="Color.Primary">.NET 10</MudLink> og
                <MudLink Href="https://mudblazor.com/" Target="_blank" Color="Color.Primary">MudBlazor</MudLink>
            </MudText>
        </MudStack>
    </MudContainer>
</footer>